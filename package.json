{
    "name": "@illavv/run_typer",
    "version": "3.0.6",
    "description": "A robust TypeScript class for type checking and validation",
    "main": "dist/Typer.cjs.min.js",
    "module": "dist/Typer.esm.min.js",
    "browser": "dist/Typer.min.js",
    "types": "dist/Typer.d.ts",
    "exports": {
        ".": {
            "import": "./dist/Typer.esm.min.js",
            "require": "./dist/Typer.cjs.min.js",
            "browser": "./dist/Typer.min.js",
            "types": "./dist/Typer.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "build": "rollup -c",
        "build:docs": "rollup -c && npx typedoc"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lavv425/Typer.git"
    },
    "keywords": [
        "typer",
        "type_validator",
        "typescript",
        "type-checking",
        "validation",
        "utility"
    ],
    "author": "Michael Lavigna",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/lavv425/Typer/issues"
    },
    "homepage": "https://github.com/lavv425/Typer",
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jest": "^30.0.0",
        "jest": "^30.3.0",
        "rollup": "^4.60.2",
        "ts-jest": "^29.4.9",
        "typedoc": "0.28.19",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "tslib": "^2.8.1"
    }
}